---
/**
 * The garden's link graph — a Canvas renderer driven by a d3-force simulation.
 *
 * Architecture (deliberately, not bandaids):
 *   - PHYSICS is d3-force (velocity-Verlet + velocityDecay/alphaDecay). It cools and *stops*,
 *     so there is no idle vibration, and Barnes-Hut charge (forceManyBody) is O(n log n), so it
 *     scales to a full vault (thousands of notes).
 *   - RENDERING is a single <canvas>. One draw call per tick; thousands of nodes stay at 60fps,
 *     where one-DOM-element-per-node would crawl.
 *   - INTERACTION is explicit hit-testing in world coordinates (click vs. drag vs. pan vs. hover),
 *     which is robust regardless of whether nodes are moving.
 *
 * Heavy analysis (communities, latent links, lenses) is precomputed at build in
 * src/lib/garden/analytics.ts; this component only lays out + renders + drives interaction.
 */
import type { GraphAnalytics } from "../lib/garden/analytics";

type Props = { data: GraphAnalytics; focus?: string; height?: number; compact?: boolean };

const { data, focus = "", height = 540, compact = false } = Astro.props;
const payload = JSON.stringify({ ...data, focus, compact });
const { stats, clusters } = data;
---
<div class:list={["gg", compact && "gg-compact"]} data-garden-graph style={`--gg-h:${height}px`}>
  {!compact && (
    <div class="gg-toolbar">
      <input class="gg-search" type="search" placeholder="search notes…" aria-label="search notes" />
      <div class="gg-seg">
        <button type="button" class="on" data-lens="links">links</button>
        <button type="button" data-lens="tags">shared tags</button>
      </div>
      <button type="button" class="gg-toggle" data-latent aria-pressed="false">latent links</button>
      <div class="gg-stats">
        <b>{stats.notes}</b> notes · <b>{stats.links}</b> links · <b>{stats.clusters}</b> clusters{stats.orphans > 0 && <> · <b>{stats.orphans}</b> orphans</>}
      </div>
    </div>
  )}

  <div class="gg-viewport">
    <canvas class="gg-canvas"></canvas>
    <div class="gg-readout" hidden></div>
    <div class="gg-tooltip" hidden></div>
    <div class="gg-hint">drag to pan · scroll to zoom · click a node · double-click to open</div>
  </div>

  {!compact && clusters.length > 0 && (
    <div class="gg-legend">
      {clusters.map((c) => (
        <button type="button" class="gg-legend-chip" data-cluster={c.id} style={`--cc:${c.color}`}>
          <span class="gg-legend-dot"></span>{c.label} <span class="gg-legend-n">{c.size}</span>
        </button>
      ))}
    </div>
  )}

  <script type="application/json" data-graph set:html={payload}></script>
</div>

<script>
  import { forceSimulation, forceLink, forceManyBody, forceX, forceY, forceCollide } from "d3-force";

  function initGraph(root: HTMLElement) {
    const dataEl = root.querySelector("[data-graph]");
    const viewport = root.querySelector(".gg-viewport") as HTMLElement;
    const canvas = root.querySelector(".gg-canvas") as HTMLCanvasElement;
    const readout = root.querySelector(".gg-readout") as HTMLElement;
    const tooltip = root.querySelector(".gg-tooltip") as HTMLElement;
    const ctx = canvas?.getContext("2d");
    if (!dataEl || !viewport || !canvas || !ctx) return;

    const raw = JSON.parse(dataEl.textContent || "{}");
    const compact: boolean = raw.compact;
    const focusSlug: string = raw.focus || "";
    const nodes: any[] = (raw.nodes || []).map((n: any) => ({ ...n }));
    if (!nodes.length) { root.classList.add("gg-empty"); return; }
    const bySlug = new Map<string, any>(nodes.map((n) => [n.slug, n]));
    const clusters: any[] = raw.clusters || [];
    const suggestions: any[] = raw.suggestions || [];
    const rawEdges: Record<string, any[]> = { links: raw.linkEdges || [], tags: raw.tagEdges || [] };

    const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c] as string));
    const mkLinks = (list: any[]) =>
      (list || []).filter((e) => bySlug.has(e.source) && bySlug.has(e.target)).map((e) => ({ source: e.source, target: e.target, weight: e.weight || 1 }));
    const lenses: Record<string, any[]> = { links: mkLinks(rawEdges.links), tags: mkLinks(rawEdges.tags) };
    let lens = "links";
    let links = lenses[lens];

    // adjacency (from raw slug pairs — d3 mutates link.source/target into node refs)
    let adj = new Map<string, Set<string>>();
    function rebuildAdj() {
      adj = new Map(nodes.map((n) => [n.slug, new Set<string>()]));
      for (const e of rawEdges[lens]) {
        if (!bySlug.has(e.source) || !bySlug.has(e.target)) continue;
        adj.get(e.source)!.add(e.target);
        adj.get(e.target)!.add(e.source);
      }
    }
    rebuildAdj();

    // ---- theme-aware palette (canvas needs concrete colors; refresh on theme toggle) ----
    let pal: Record<string, string> = {};
    let mono = "monospace";
    function readPalette() {
      const cs = getComputedStyle(document.documentElement);
      const g = (v: string) => cs.getPropertyValue(v).trim();
      pal = { wire: g("--wire"), wireOn: g("--wire-on"), surface: g("--surface"), surface2: g("--surface-2"),
        text: g("--text-bright"), textSub: g("--text-sub"), dim: g("--dim"), amber: g("--amber") };
      mono = g("--mono") || "monospace";
    }
    readPalette();

    // ---- canvas sizing (DPR-aware) ----
    let cssW = 0, cssH = 0, dpr = 1;
    function resize() {
      dpr = window.devicePixelRatio || 1;
      cssW = viewport.clientWidth;
      cssH = viewport.clientHeight;
      canvas.width = Math.round(cssW * dpr);
      canvas.height = Math.round(cssH * dpr);
      canvas.style.width = cssW + "px";
      canvas.style.height = cssH + "px";
    }
    resize();

    const radius = (n: any) => 3.6 + Math.sqrt(n.degree || 0) * 1.7;

    // ---- camera (world → screen: s = world*scale + t) ----
    let scale = 1, tx = cssW / 2, ty = cssH / 2;
    let autoFit = true;
    const toWorld = (px: number, py: number) => ({ x: (px - tx) / scale, y: (py - ty) / scale });
    function fit() {
      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      for (const n of nodes) { minX = Math.min(minX, n.x); maxX = Math.max(maxX, n.x); minY = Math.min(minY, n.y); maxY = Math.max(maxY, n.y); }
      if (!isFinite(minX)) return;
      const pad = 70, bw = maxX - minX + pad * 2, bh = maxY - minY + pad * 2;
      scale = Math.min(cssW / bw, cssH / bh, 1.6);
      if (!isFinite(scale) || scale <= 0) scale = 1;
      tx = cssW / 2 - ((minX + maxX) / 2) * scale;
      ty = cssH / 2 - ((minY + maxY) / 2) * scale;
    }

    // ---- custom force: gentle pull toward each community's centroid (scaled by alpha → cools cleanly) ----
    function clusterForce(strength: number) {
      let ns: any[] = [];
      const force: any = (alpha: number) => {
        const cen = new Map<number, { x: number; y: number; n: number }>();
        for (const n of ns) { if (n.community < 0) continue; const c = cen.get(n.community) || cen.set(n.community, { x: 0, y: 0, n: 0 }).get(n.community)!; c.x += n.x; c.y += n.y; c.n++; }
        for (const c of cen.values()) { c.x /= c.n; c.y /= c.n; }
        for (const n of ns) { const c = cen.get(n.community); if (!c) continue; n.vx += (c.x - n.x) * strength * alpha; n.vy += (c.y - n.y) * strength * alpha; }
      };
      force.initialize = (n: any[]) => { ns = n; };
      return force;
    }

    let tickCount = 0;
    const sim = forceSimulation(nodes)
      .force("link", forceLink(links).id((d: any) => d.slug).distance(() => (lens === "tags" ? 64 : 46)).strength((l: any) => 0.05 + 0.25 * Math.min(1, l.weight / 3)))
      .force("charge", forceManyBody().strength(-110).theta(0.9).distanceMax(700))
      .force("x", forceX(0).strength(0.045))
      .force("y", forceY(0).strength(0.045))
      .force("collide", forceCollide().radius((n: any) => radius(n) + 3))
      .force("cluster", clusterForce(0.18))
      .velocityDecay(0.45)
      .on("tick", () => { tickCount++; if (autoFit && tickCount < 70) fit(); draw(); })
      .on("end", () => { autoFit = false; });

    // ---- interaction state ----
    let selected = focusSlug && bySlug.has(focusSlug) ? focusSlug : "";
    let hovered = "";
    let isolatedCluster: number | null = null;
    let searchHits: Set<string> | null = null;
    let showLatent = false;

    function neighborsOf(slug: string) {
      const set = new Set<string>([slug]);
      for (const v of adj.get(slug) || []) set.add(v);
      return set;
    }
    function activeSet(): Set<string> | null {
      if (searchHits) return searchHits;
      if (isolatedCluster != null) { const s = new Set<string>(); for (const n of nodes) if (n.community === isolatedCluster) s.add(n.slug); return s; }
      const key = hovered || selected;
      return key ? neighborsOf(key) : null;
    }

    // ---- draw ----
    function draw() {
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.clearRect(0, 0, cssW, cssH);
      ctx.setTransform(scale * dpr, 0, 0, scale * dpr, tx * dpr, ty * dpr);
      const active = activeSet();
      const center = hovered || selected;

      const groups = new Map<number, any[]>();
      for (const n of nodes) if (n.community >= 0) (groups.get(n.community) || groups.set(n.community, []).get(n.community)!).push(n);

      // cluster halos
      for (const [id, members] of groups) {
        const cl = clusters.find((c) => c.id === id);
        if (!cl) continue;
        let cx = 0, cy = 0;
        for (const m of members) { cx += m.x; cy += m.y; }
        cx /= members.length; cy /= members.length;
        let r = 40;
        for (const m of members) r = Math.max(r, Math.hypot(m.x - cx, m.y - cy));
        ctx.globalAlpha = active ? 0.05 : 0.09;
        ctx.fillStyle = cl.color;
        ctx.beginPath(); ctx.arc(cx, cy, r + 34, 0, Math.PI * 2); ctx.fill();
      }
      ctx.globalAlpha = 1;

      // edges
      ctx.lineWidth = 1.1 / scale;
      for (const l of links) {
        const s = l.source, t = l.target;
        const on = active && active.has(s.slug) && active.has(t.slug);
        ctx.strokeStyle = on ? pal.wireOn : pal.wire;
        ctx.globalAlpha = active ? (on ? 0.95 : 0.07) : 0.5;
        ctx.beginPath(); ctx.moveTo(s.x, s.y); ctx.lineTo(t.x, t.y); ctx.stroke();
      }
      ctx.globalAlpha = 1;

      // latent (suggested) links
      if (showLatent) {
        ctx.save();
        ctx.setLineDash([3 / scale, 5 / scale]);
        ctx.lineWidth = 1.3 / scale;
        ctx.strokeStyle = pal.amber;
        ctx.globalAlpha = 0.55;
        for (const sug of suggestions) {
          const a = bySlug.get(sug.a), b = bySlug.get(sug.b);
          if (!a || !b) continue;
          ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(b.x, b.y); ctx.stroke();
        }
        ctx.restore();
      }

      // nodes
      for (const n of nodes) {
        const on = !active || active.has(n.slug);
        ctx.globalAlpha = on ? 1 : 0.12;
        const r = radius(n);
        ctx.beginPath(); ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
        ctx.fillStyle = n.orphan ? pal.surface2 : n.color;
        ctx.fill();
        ctx.lineWidth = 1.5 / scale; ctx.strokeStyle = pal.surface; ctx.stroke();
        if (n.slug === center || n.slug === selected) {
          ctx.lineWidth = 2 / scale; ctx.strokeStyle = pal.text;
          ctx.beginPath(); ctx.arc(n.x, n.y, r + 3.5 / scale, 0, Math.PI * 2); ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;

      // node labels (rule-based to stay legible at scale)
      const showAll = compact || nodes.length <= 60;
      ctx.font = `${11 / scale}px ${mono}`;
      ctx.textAlign = "center";
      ctx.textBaseline = "top";
      ctx.lineWidth = 3 / scale;
      ctx.lineJoin = "round";
      for (const n of nodes) {
        const isActive = !active || active.has(n.slug);
        const show = (showAll && isActive) || n.hub || n.slug === center || (active && active.has(n.slug));
        if (!show) continue;
        ctx.globalAlpha = isActive ? 1 : 0.25;
        const text = n.title.length > 26 ? n.title.slice(0, 24) + "…" : n.title;
        const ly = n.y + radius(n) + 3 / scale;
        ctx.strokeStyle = pal.surface;
        ctx.strokeText(text, n.x, ly);
        ctx.fillStyle = n.slug === center ? pal.text : pal.textSub;
        ctx.fillText(text, n.x, ly);
      }
      ctx.globalAlpha = 1;

      // cluster labels
      ctx.font = `600 ${13 / scale}px ${mono}`;
      for (const [id, members] of groups) {
        const cl = clusters.find((c) => c.id === id);
        if (!cl) continue;
        let cx = 0, minY = Infinity;
        for (const m of members) { cx += m.x; minY = Math.min(minY, m.y); }
        cx /= members.length;
        ctx.globalAlpha = active ? 0.4 : 0.72;
        ctx.fillStyle = cl.color;
        ctx.strokeStyle = pal.surface;
        ctx.strokeText(cl.label, cx, minY - 24 / scale);
        ctx.fillText(cl.label, cx, minY - 24 / scale);
      }
      ctx.globalAlpha = 1;
    }

    function redrawIfIdle() { if (sim.alpha() <= sim.alphaMin()) draw(); }

    // ---- hit testing ----
    function hitTest(px: number, py: number) {
      const w = toWorld(px, py);
      let best: any = null, bestD = Infinity;
      for (const n of nodes) {
        const d = Math.hypot(n.x - w.x, n.y - w.y);
        if (d <= radius(n) + 9 / scale && d < bestD) { bestD = d; best = n; }
      }
      return best;
    }
    const localXY = (e: PointerEvent | MouseEvent) => { const r = canvas.getBoundingClientRect(); return { x: e.clientX - r.left, y: e.clientY - r.top }; };

    // ---- pointer interaction (click vs drag vs pan vs hover) ----
    let mode: "none" | "pan" | "drag" = "none";
    let dragNode: any = null;
    let pressedNode: any = null;
    let lastX = 0, lastY = 0, movedDist = 0;

    canvas.addEventListener("pointerdown", (e) => {
      canvas.setPointerCapture(e.pointerId);
      const { x, y } = localXY(e);
      movedDist = 0; lastX = e.clientX; lastY = e.clientY;
      pressedNode = hitTest(x, y);
      if (pressedNode) {
        mode = "drag"; dragNode = pressedNode; autoFit = false;
        sim.alphaTarget(0.3).restart();
        dragNode.fx = dragNode.x; dragNode.fy = dragNode.y;
      } else {
        mode = "pan"; canvas.style.cursor = "grabbing";
      }
    });

    canvas.addEventListener("pointermove", (e) => {
      movedDist += Math.abs(e.movementX) + Math.abs(e.movementY);
      if (mode === "drag" && dragNode) {
        const { x, y } = localXY(e);
        const w = toWorld(x, y);
        dragNode.fx = w.x; dragNode.fy = w.y;
      } else if (mode === "pan") {
        tx += e.clientX - lastX; ty += e.clientY - lastY; lastX = e.clientX; lastY = e.clientY; draw();
      } else {
        const { x, y } = localXY(e);
        const n = hitTest(x, y);
        const slug = n ? n.slug : "";
        canvas.style.cursor = n ? "pointer" : "grab";
        if (slug !== hovered) { hovered = slug; showTooltip(n, x, y); redrawIfIdle(); }
        else if (n) moveTooltip(x, y);
      }
    });

    function endPointer(e: PointerEvent) {
      if (mode === "drag" && dragNode) { dragNode.fx = null; dragNode.fy = null; sim.alphaTarget(0); }
      if (movedDist < 5) {
        if (pressedNode) onActivate(pressedNode);
        else { selected = ""; isolatedCluster = null; hideReadout(); draw(); }
      }
      mode = "none"; dragNode = null; pressedNode = null; canvas.style.cursor = "grab";
    }
    canvas.addEventListener("pointerup", endPointer);
    canvas.addEventListener("pointercancel", () => { if (dragNode) { dragNode.fx = null; dragNode.fy = null; sim.alphaTarget(0); } mode = "none"; dragNode = null; });

    canvas.addEventListener("dblclick", (e) => {
      const { x, y } = localXY(e);
      const n = hitTest(x, y);
      if (n) window.location.href = `/garden/${n.slug}`;
    });

    canvas.addEventListener("wheel", (e) => {
      e.preventDefault();
      autoFit = false;
      const { x: mx, y: my } = localXY(e);
      const next = Math.min(4, Math.max(0.08, scale * (e.deltaY < 0 ? 1.12 : 0.89)));
      tx = mx - ((mx - tx) * next) / scale; ty = my - ((my - ty) * next) / scale; scale = next;
      draw();
    }, { passive: false });

    function onActivate(n: any) {
      if (compact) { window.location.href = `/garden/${n.slug}`; return; } // mini graph: click opens
      selected = n.slug; isolatedCluster = null; showReadout(n); draw();
    }

    // ---- tooltip (full graph, where most labels are culled) ----
    function showTooltip(n: any, x: number, y: number) {
      if (!n || compact) { tooltip.hidden = true; return; }
      tooltip.textContent = n.title;
      tooltip.hidden = false;
      moveTooltip(x, y);
    }
    function moveTooltip(x: number, y: number) { tooltip.style.left = `${x + 12}px`; tooltip.style.top = `${y + 14}px`; }

    // ---- readout panel ----
    function hideReadout() { readout.hidden = true; }
    function showReadout(n: any) {
      if (compact) return;
      const nbrs = [...(adj.get(n.slug) || [])].map((s) => bySlug.get(s)).filter(Boolean).sort((a, b) => b.degree - a.degree);
      const sugg = suggestions.filter((s) => s.a === n.slug || s.b === n.slug).slice(0, 4);
      readout.innerHTML =
        `<button class="gg-readout-x" aria-label="close">×</button>` +
        `<a class="gg-readout-title" href="/garden/${n.slug}">${esc(n.title)} ↗</a>` +
        (nbrs.length
          ? `<div class="gg-readout-sec">connected (${nbrs.length})</div><div class="gg-readout-links">` +
            nbrs.slice(0, 8).map((m) => `<a href="/garden/${m.slug}">${esc(m.title)}</a>`).join("") + `</div>`
          : `<div class="gg-readout-sec gg-readout-orphan">orphan — not linked yet</div>`) +
        (sugg.length
          ? `<div class="gg-readout-sec">could connect to</div><div class="gg-readout-links">` +
            sugg.map((s) => {
              const o = s.a === n.slug ? { slug: s.b, title: s.bTitle } : { slug: s.a, title: s.aTitle };
              const why = s.shared?.length ? ` <em>via ${s.shared.map(esc).join(", ")}</em>` : "";
              return `<a class="gg-suggest" href="/garden/${o.slug}">${esc(o.title)}${why}</a>`;
            }).join("") + `</div>`
          : "");
      readout.hidden = false;
      readout.querySelector(".gg-readout-x")?.addEventListener("click", () => { selected = ""; hideReadout(); draw(); });
    }

    // ---- toolbar / lens / latent / legend ----
    if (!compact) {
      const search = root.querySelector(".gg-search") as HTMLInputElement;
      search?.addEventListener("input", () => {
        const q = search.value.trim().toLowerCase();
        searchHits = q ? new Set(nodes.filter((n) => n.title.toLowerCase().includes(q)).map((n) => n.slug)) : null;
        redrawIfIdle();
      });

      root.querySelectorAll("[data-lens]").forEach((btn) =>
        btn.addEventListener("click", () => {
          const next = btn.getAttribute("data-lens")!;
          if (next === lens) return;
          lens = next;
          root.querySelectorAll("[data-lens]").forEach((b) => b.classList.toggle("on", b === btn));
          links = lenses[lens];
          rebuildAdj();
          (sim.force("link") as any).links(links);
          selected = ""; isolatedCluster = null; hideReadout();
          autoFit = true; tickCount = 0;
          sim.alpha(0.7).restart();
        }),
      );

      const latentBtn = root.querySelector("[data-latent]") as HTMLButtonElement;
      latentBtn?.addEventListener("click", () => {
        showLatent = !showLatent;
        latentBtn.classList.toggle("on", showLatent);
        latentBtn.setAttribute("aria-pressed", String(showLatent));
        redrawIfIdle();
      });

      root.querySelectorAll(".gg-legend-chip").forEach((chip) =>
        chip.addEventListener("click", () => {
          const id = Number(chip.getAttribute("data-cluster"));
          const on = isolatedCluster !== id;
          isolatedCluster = on ? id : null;
          root.querySelectorAll(".gg-legend-chip").forEach((c) => c.classList.toggle("on", c === chip && on));
          if (on) { selected = ""; hideReadout(); }
          redrawIfIdle();
        }),
      );
    }

    // theme toggle → refresh palette + redraw
    new MutationObserver(() => { readPalette(); redrawIfIdle(); }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
    // responsive
    let resizeRaf = 0;
    window.addEventListener("resize", () => {
      cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => { resize(); if (sim.alpha() <= sim.alphaMin()) { fit(); draw(); } });
    }, { passive: true });

    if (selected) { const n = bySlug.get(selected); if (n) showReadout(n); }
  }

  document.querySelectorAll<HTMLElement>("[data-garden-graph]").forEach(initGraph);
</script>
