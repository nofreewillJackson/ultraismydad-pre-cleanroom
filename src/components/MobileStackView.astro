      flex-direction:column;
    }
    .mobile-stack-panel.open { opacity:1; transform:scale(1); pointer-events:auto; }
    .mobile-panel-h {
      background:var(--bg);
      padding:8px 13px 7px;
      border-bottom:1px solid var(--border);
