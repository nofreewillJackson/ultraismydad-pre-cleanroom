    .mobile-final-tally .sep { color:var(--dimmer); margin:0 5px; }
    .mobile-stack-panel {
      position:absolute;
      inset:0;
      background:var(--bg);
      z-index:30;
      opacity:0;
      transform:scale(.18);
      transition:opacity .26s ease-out, transform .26s cubic-bezier(.2,.7,.2,1);
      pointer-events:none;
      transform-origin:50% 50%;
