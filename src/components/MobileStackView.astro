      font-size:11.5px;
      line-height:1.15;
      flex:1;
      min-width:0;
      overflow:hidden;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
    }
    .mobile-tmeta {
