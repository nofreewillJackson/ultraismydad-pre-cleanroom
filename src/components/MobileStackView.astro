    }
    .mobile-dcard-h .nname { text-overflow:ellipsis; white-space:nowrap; }
    .mobile-fcard-h .nname { line-height:1.35; }
    .mobile-dcard-h .ntag,
    .mobile-fcard-h .ntag {
      flex-shrink:0;
      font-size:9.5px;
      border-radius:3px;
      padding:1px 6px;
      font-family:var(--mono);
    }
    .mobile-dcard-h .ntag {
      color:var(--amber);
      border:0;
      padding:1px 0;
    }
    .mobile-demo-toggle {
      flex-shrink:0;
      border:1px solid var(--amber);
      border-radius:3px;
      background:transparent;
      color:var(--amber);
      font-family:var(--mono);
      font-size:9.5px;
      line-height:1.2;
      padding:1px 6px;
      cursor:pointer;
      appearance:none;
      -webkit-appearance:none;
    }
    .mobile-demo-toggle:hover { color:var(--text-bright); border-color:var(--text-bright); }
    .mobile-dcard-embed {
      width:100%;
      aspect-ratio:9/16;
      background:var(--surface-2);
      border:0;
      display:block;
    }
    .mobile-dcard-embed.wide { aspect-ratio:4/3; }
    .mobile-dcard.collapsed .mobile-dcard-embed { display:none; }
    .mobile-dcard-foot {
