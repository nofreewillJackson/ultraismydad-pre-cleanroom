</style>

<script define:vars={{ mobileStackData: data }}>
  const mobileData = mobileStackData;
  const mobileShell = document.getElementById("mobileStackShell");
  const mobileHome = document.getElementById("mobileStackHome");
  const mobileTechHome = document.getElementById("mobileTechHome");
  const mobilePanel = document.getElementById("mobileTechPanel");
  const mobilePanelName = document.getElementById("mobileTechPanelName");
  const mobilePanelTag = document.getElementById("mobileTechPanelTag");
  const mobilePanelMeta = document.getElementById("mobileTechPanelMeta");
  const mobilePanelBody = document.getElementById("mobileTechPanelBody");
  const mobileBack = document.getElementById("mobileTechBack");

  const catLabels = { frontend: "front-end", api: "api", data: "data", infra: "infra", media: "media" };
  const catCls = (id) => id === "frontend" ? "fe" : (id || "infra");
  const catLabel = (id) => catLabels[id] || id || "other";

  function esc(value) {
    return String(value || "").replace(/[&<>"']/g, (char) => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;",
    })[char]);
  }
  function attr(value) {
    return esc(value).replace(/`/g, "&#96;");
  }
  function shortUrl(url) {
    return String(url || "").replace(/^https?:\/\//, "").replace(/\/$/, "");
  }
  function chipsLine(techIds) {
    if (!techIds || !techIds.length) return "";
    return techIds.map((id) => mobileData.techById[id]?.name || id).filter(Boolean).join(" · ");
  }
  function metaForTech(id) {
    const matches = mobileData.items.filter((item) => item.techIds.includes(id));
    const projects = new Set(matches.map((item) => item.projectId).filter(Boolean));
    const sorted = [...matches].sort((a, b) => (b.dateValue || 0) - (a.dateValue || 0) || a.title.localeCompare(b.title));
    const last = sorted[0];
    return {
      projects: projects.size,
      entries: matches.length,
      lastProject: last ? mobileData.projects[last.projectId]?.name : "",
      lastDate: last?.dateLabel || "",
    };
  }
  function statsForCategory(category) {
    return mobileData.categoryStats?.[category] || { projects: 0, updates: 0, demos: 0 };
  }
  function totalStats() {
    return mobileData.totalStats || { projects: 0, updates: 0, demos: 0 };
  }
  function statsMarkup(stats, short = false) {
    const labels = short
      ? ["proj", "upd", "demo"]
      : ["projects", "updates", "demos"];
    return `<span class="cat-stats">${labels[0]} <b>${stats.projects}</b><span class="sep">·</span>${labels[1]} <b>${stats.updates}</b><span class="sep">·</span>${labels[2]} <b>${stats.demos}</b></span>`;
  }
  function renderHome() {
    if (!mobileTechHome) return;
    let previousCategory = "frontend";
    const frontendStats = statsForCategory("frontend");
    const total = totalStats();
    let html = `<div class="mobile-axis-row"><b>▲ FRONT-END</b><span class="line"></span><span>BACK-END ▼</span></div><div class="mobile-tech-grid">
      <div class="mobile-cat-label fe first">fe${statsMarkup(frontendStats, true)}</div>
      <div class="mobile-hero-text">
        <h1 class="mobile-hero-title">projects</h1>
        <p class="mobile-hero-desc">Tap on a tech tile to view individual projects.<br>Also check out <a href="/list" class="mobile-hero-link">List View</a>.</p>
      </div>`;
    for (const tech of mobileData.techs) {
      const meta = metaForTech(tech.id);
      const empty = meta.entries === 0;
      if (tech.category !== previousCategory && previousCategory) {
        html += `<div class="mobile-cat-label ${esc(catCls(tech.category))}">${esc(catLabel(tech.category))}${statsMarkup(statsForCategory(tech.category))}</div>`;
      }
      previousCategory = tech.category;
      html += `<button class="mobile-tile ${esc(catCls(tech.category))}${empty ? " empty" : ""}" type="button" data-tech="${esc(tech.id)}">
        <div class="mobile-ttop"><span class="mobile-tdot"></span><span class="mobile-tname">${esc(tech.name)}</span></div>
        <div class="mobile-tmeta">
          ${empty ? `<div class="mobile-tm-count">no updates yet</div>` : `<div class="mobile-tm-count">${meta.projects} project${meta.projects === 1 ? "" : "s"}</div><div class="mobile-tm-proj">${esc(meta.lastProject || "—")}</div><div class="mobile-tm-date">${esc(meta.lastDate)}</div>`}
        </div>
      </button>`;
    }
    html += `</div><div class="mobile-final-tally">total<span class="sep">·</span><b>${total.projects}</b> projects<span class="sep">·</span><b>${total.updates}</b> updates<span class="sep">·</span><b>${total.demos}</b> demos</div>`;
    mobileTechHome.innerHTML = html;
  }
  function demoCardHtml(item) {
    const embed = item.demoUrl
      ? `<iframe class="mobile-dcard-embed" src="${attr(item.demoUrl)}" loading="lazy" sandbox="allow-scripts allow-same-origin allow-popups allow-forms"></iframe>`
      : `<iframe class="mobile-dcard-embed wide" sandbox="allow-scripts" srcdoc="${attr(item.artifactHtml || "")}" loading="lazy"></iframe>`;
    return `<div class="mobile-dcard">
      <div class="mobile-dcard-h"><span class="glyph">▣</span><span class="nname">${esc(item.title)}</span><span class="ntag">demo</span><button class="mobile-demo-toggle" type="button" data-demo-toggle aria-expanded="true">hide</button></div>
      ${embed}
      <div class="mobile-dcard-foot">
        <div>${esc(item.desc)}</div>
        ${item.techIds?.length ? `<div class="mobile-accent" style="margin-top:3px">${esc(chipsLine(item.techIds))}</div>` : ""}
        ${item.route ? `<div style="margin-top:3px"><a href="${attr(item.route)}">open entry ↗</a></div>` : ""}
        ${item.demoUrl ? `<div style="margin-top:3px"><a href="${attr(item.demoUrl)}" target="_blank" rel="noreferrer">open ↗ ${esc(shortUrl(item.demoUrl))}</a></div>` : ""}
      </div>
    </div>`;
  }
  function featureCardHtml(item, isSeries = false) {
    const card = `<div class="mobile-fcard ${isSeries ? "series" : ""}">
      <div class="mobile-fcard-h"><span class="sdot"></span><span class="nname">${esc(item.title)}</span><span class="ntag">${isSeries ? "series" : "update"}</span></div>
      <div class="mobile-fcard-body">
        <p class="ndesc">${esc(item.desc)}</p>
        <div class="nmeta">
          ${item.status && !isSeries ? `<span class="mobile-status">${esc(item.status)}</span>` : ""}
          <span>${esc(item.meta || item.dateLabel || "")}</span>
          ${item.techIds?.length ? `<span>·</span><span>${esc(chipsLine(item.techIds))}</span>` : ""}
        </div>
      </div>
    </div>`;
    return !isSeries && item.route ? `<a class="mobile-fcard-link" href="${attr(item.route)}">${card}</a>` : card;
  }
  function episodeRowHtml(item) {
    const thumb = item.thumbnailUrl || (item.youtubeId ? `https://img.youtube.com/vi/${item.youtubeId}/hqdefault.jpg` : "");
    return `<a class="mobile-ep-row" href="${attr(item.route || "#")}">
      <div class="mobile-ep-thumb ${item.orient === "v" ? "v" : ""}"${thumb ? ` style="background-image:url('${attr(thumb)}')"` : ""}></div>
      <div class="ecol"><span class="ename">${esc(item.title)}</span><span class="emeta">${esc(item.dateLabel || "")}</span></div>
      <span class="play">▶</span>
    </a>`;
  }
  function buildExpandChildren(projectId) {
    const children = mobileData.childrenByProject[projectId] || { demos: [], updates: [], series: [] };
    if (!children.demos.length && !children.updates.length && !children.series.length) {
      return '<div class="mobile-empty-state">no features or demos yet.</div>';
    }
    let html = '<div class="mobile-wire"></div>';
    children.demos.forEach((item) => { html += demoCardHtml(item); });
    children.updates.forEach((item) => { html += featureCardHtml(item); });
    children.series.forEach((series, index) => {
      if (index > 0) html += '<hr class="mobile-series-sep">';
      html += featureCardHtml(series, true);
      if (series.episodes?.length) {
        html += '<div class="mobile-ep-group">';
        series.episodes.forEach((episode) => { html += episodeRowHtml(episode); });
        html += '</div>';
      }
    });
    return html;
  }
  function openTechPanel(techId, origin) {
    const tech = mobileData.techById[techId];
    if (!tech || !mobilePanel) return;
    const matches = mobileData.items.filter((item) => item.techIds.includes(techId));
    const projectIds = [...new Set(matches.map((item) => item.projectId).filter(Boolean))];
    const meta = metaForTech(techId);
    mobilePanelName.textContent = tech.name;
    mobilePanelTag.textContent = catLabel(tech.category);
    mobilePanelTag.className = `mobile-panel-tag ${catCls(tech.category)}`;
    mobilePanelMeta.innerHTML = projectIds.length
      ? `<b>${projectIds.length}</b> project${projectIds.length === 1 ? "" : "s"}<span class="sep">·</span><b>${meta.entries}</b> entr${meta.entries === 1 ? "y" : "ies"}${meta.lastDate ? `<span class="sep">·</span>last update <b>${esc(meta.lastDate)}</b>` : ""}`
      : `no shipped features or demos using <b>${esc(tech.name)}</b> yet`;
    mobilePanelBody.innerHTML = projectIds.length ? projectIds.map((projectId) => {
      const project = mobileData.projects[projectId];
      if (!project) return "";
      const projectMatches = matches.filter((item) => item.projectId === projectId);
      const featureCount = projectMatches.filter((item) => item.type !== "demo").length;
      const demoCount = projectMatches.filter((item) => item.type === "demo").length;
      const countBits = [];
      if (featureCount) countBits.push(`<span class="mobile-accent">${featureCount}</span> feature${featureCount === 1 ? "" : "s"}`);
      if (demoCount) countBits.push(`<span class="mobile-accent">${demoCount}</span> demo${demoCount === 1 ? "" : "s"}`);
      return `<div class="mobile-project-group" data-project="${esc(projectId)}">
        <div class="mobile-pcard">
          <div class="mobile-pcard-h"><span class="glyph">${esc(project.mark || "$_")}</span><span class="nname">${esc(project.name)}</span><span class="caret">▾</span><span class="ntag">project</span></div>
          <div class="mobile-pcard-body"><p class="ndesc">${esc(project.desc)}</p><div class="nmeta"><span>${esc(project.meta)}</span>${countBits.length ? `<span>·</span><span>${countBits.join(" · ")}</span>` : ""}</div></div>
        </div>
        <div class="mobile-expand-children">${buildExpandChildren(projectId)}</div>
      </div>`;
    }).join("") : `<div class="mobile-empty-state">when a feature ships with this stack tag, it appears here.</div>`;
    if (origin && mobileShell) {
      const rect = mobileShell.getBoundingClientRect();
      mobilePanel.style.transformOrigin = `${origin.x - rect.left}px ${origin.y - rect.top}px`;
    } else {
      mobilePanel.style.transformOrigin = "50% 50%";
    }
    requestAnimationFrame(() => {
      mobilePanel.classList.add("open");
      mobilePanel.setAttribute("aria-hidden", "false");
    });
  }
  function closeTechPanel() {
    mobilePanel?.classList.remove("open");
    mobilePanel?.setAttribute("aria-hidden", "true");
  }

  renderHome();
  mobileHome?.addEventListener("click", (event) => {
    const tile = event.target.closest(".mobile-tile");
    if (!tile) return;
    const rect = tile.getBoundingClientRect();
    openTechPanel(tile.dataset.tech, { x: rect.left + rect.width / 2, y: rect.top + rect.height / 2 });
  });
  mobileBack?.addEventListener("click", closeTechPanel);
  mobilePanelBody?.addEventListener("click", (event) => {
    const toggle = event.target.closest("[data-demo-toggle]");
    if (toggle) {
      const card = toggle.closest(".mobile-dcard");
      if (!card) return;
      const collapsed = card.classList.toggle("collapsed");
      toggle.textContent = collapsed ? "show" : "hide";
      toggle.setAttribute("aria-expanded", String(!collapsed));
      return;
    }
    if (event.target.closest(".mobile-expand-children")) return;
    const card = event.target.closest(".mobile-pcard");
    if (!card) return;
    card.closest(".mobile-project-group")?.classList.toggle("expanded");
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && mobilePanel?.classList.contains("open")) closeTechPanel();
  });
  mobileHome?.addEventListener("scroll", (event) => {
    document.getElementById("topbar")?.classList.toggle("stuck", (event.currentTarget.scrollTop || 0) > 6);
  }, { passive:true });
</script>
