    .mobile-project-group.expanded .mobile-pcard-h .caret { transform:rotate(180deg); color:var(--green); }
    .mobile-pcard-h .ntag {
      font-size:10px;
      color:var(--green);
      border:1px solid var(--green-border);
      border-radius:3px;
      padding:1px 6px;
      font-family:var(--mono);
    }
    .mobile-pcard-body { padding:9px 12px 11px; }
    .mobile-pcard-body .ndesc,
    .mobile-fcard-body .ndesc {
      color:var(--text-sub);
      line-height:1.55;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
      overflow:hidden;
    }
    .mobile-pcard-body .ndesc { font-size:12px; }
    .mobile-pcard-body .nmeta {
      margin-top:8px;
      font-family:var(--mono);
      font-size:10.5px;
      color:var(--dim);
      display:flex;
      flex-wrap:wrap;
      gap:5px 9px;
    }
    .mobile-accent { color:var(--green); }
    .mobile-expand-children { display:none; }
    .mobile-project-group.expanded .mobile-expand-children { display:block; }
    .mobile-expand-children > * { margin-bottom:8px; }
    .mobile-expand-children > *:last-child { margin-bottom:0; }
    .mobile-wire {
      display:block;
      width:1.4px;
      height:14px;
      background:var(--wire);
      opacity:.7;
      margin:0 auto;
    }
    .mobile-ep-group { padding-left:22px; }
    .mobile-ep-group > * { margin-bottom:6px; }
    .mobile-ep-group > *:last-child { margin-bottom:0; }
    .mobile-series-sep { margin:14px 6px; height:1px; background:var(--border); border:0; }
    .mobile-dcard-h,
    .mobile-fcard-h {
      display:flex;
      align-items:flex-start;
      gap:7px;
      padding:9px 11px;
      border-bottom:1px solid var(--border);
    }
    .mobile-dcard-h { align-items:center; background:var(--amber-bg); }
    .mobile-dcard-h .glyph { color:var(--amber); font-family:var(--mono); font-size:10px; }
    .mobile-dcard-h .nname,
    .mobile-fcard-h .nname {
      flex:1;
      color:var(--text-bright);
      font-weight:600;
      font-size:12.5px;
      min-width:0;
