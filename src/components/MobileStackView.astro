---
type Props = {
  data: any;
};

const { data: rawData } = Astro.props;
const stackCategories = ["frontend", "api", "data", "infra", "media"];
const collectMobileItems = (source: any) => {
  const byId = new Map();
  const addItem = (item: any) => {
    if (!item) return;
    const key = item.id || `${item.type || "item"}:${item.projectId || ""}:${item.title || ""}`;
    if (!byId.has(key)) byId.set(key, item);
  };
  (source.items || []).forEach(addItem);
  Object.values(source.childrenByProject || {}).forEach((children: any) => {
    (children?.demos || []).forEach(addItem);
    (children?.updates || []).forEach(addItem);
    (children?.series || []).forEach((series: any) => {
      addItem(series);
      (series?.episodes || []).forEach(addItem);
    });
  });
  return [...byId.values()];
};
const mobileItemsForStats = collectMobileItems(rawData);
const makeCategoryStats = (category: string) => {
  const techIds = new Set((rawData.techs || []).filter((tech: any) => tech.category === category).map((tech: any) => tech.id));
  const projects = new Set();
  const updateIds = new Set();
  const demoIds = new Set();
  mobileItemsForStats.forEach((item: any) => {
    const itemTechIds = Array.isArray(item.techIds) ? item.techIds : [];
    if (!itemTechIds.some((id: string) => techIds.has(id))) return;
    if (item.projectId) projects.add(item.projectId);
    if (item.type === "demo") demoIds.add(item.id || `${item.projectId}:${item.title}`);
    else if (item.type === "update") updateIds.add(item.id || `${item.projectId}:${item.title}`);
  });
  return { projects: projects.size, updates: updateIds.size, demos: demoIds.size };
};
const makeTotalStats = () => {
  const projects = new Set();
  const updateIds = new Set();
  const demoIds = new Set();
  mobileItemsForStats.forEach((item: any) => {
    if (item.projectId) projects.add(item.projectId);
    if (item.type === "demo") demoIds.add(item.id || `${item.projectId}:${item.title}`);
    else if (item.type === "update") updateIds.add(item.id || `${item.projectId}:${item.title}`);
  });
  return { projects: projects.size, updates: updateIds.size, demos: demoIds.size };
};
const data = {
  ...rawData,
  categoryStats: Object.fromEntries(stackCategories.map((category) => [category, makeCategoryStats(category)])),
  totalStats: makeTotalStats(),
};
---
<section class="mobile-stack-shell" id="mobileStackShell" aria-label="mobile stack view">
  <div class="mobile-stack-home" id="mobileStackHome">
    <div id="mobileTechHome"></div>
  </div>
  <div class="mobile-stack-panel" id="mobileTechPanel" aria-hidden="true">
    <div class="mobile-panel-h">
      <div class="mobile-panel-h-row">
        <button class="mobile-panel-back" id="mobileTechBack" type="button">← projects</button>
        <span class="mobile-panel-name" id="mobileTechPanelName"></span>
        <span class="mobile-panel-tag" id="mobileTechPanelTag"></span>
      </div>
      <div class="mobile-panel-meta" id="mobileTechPanelMeta"></div>
    </div>
    <div class="mobile-panel-body" id="mobileTechPanelBody"></div>
  </div>
</section>

<style is:global>
  .mobile-stack-shell { display:none; }
  @media (max-width:720px) {
    html[data-theme="dark"] .mobile-stack-shell {
      --bg:#040506;
      --surface:#13161a;
      --surface-2:#1a1e23;
      --grid-line:#0b0d10;
      --grid-dot:#181b20;
      --wire:#2b3038;
    }
    html[data-theme="light"] .mobile-stack-shell {
      --grid-line:#dee1e3;
      --grid-dot:#cdd1d4;
      --wire:#a8adb5;
    }
    .mobile-stack-shell {
      display:block;
      position:relative;
      height:calc(100vh - 54px);
      overflow:hidden;
      background:var(--bg);
      max-width:480px;
      margin:0 auto;
    }
    .stack-mobile-fallback { display:none !important; }
    .mobile-stack-home {
      height:100%;
      overflow-y:auto;
      overflow-x:hidden;
      padding:10px 14px 60px;
      background:
        linear-gradient(var(--grid-line) 1px, transparent 1px) 0 0 / 160px 160px,
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px) 0 0 / 160px 160px,
        radial-gradient(var(--grid-dot) 1px, transparent 1px) 0 0 / 32px 32px,
        var(--bg);
      scrollbar-width:thin;
      -webkit-overflow-scrolling:touch;
    }
    .mobile-stack-home::-webkit-scrollbar,
    .mobile-panel-body::-webkit-scrollbar { width:3px; }
    .mobile-stack-home::-webkit-scrollbar-thumb,
    .mobile-panel-body::-webkit-scrollbar-thumb { background:var(--border-strong); border-radius:2px; }
    .mobile-axis-row {
      display:flex;
      align-items:center;
      gap:8px;
      padding:2px 2px 9px;
      font-family:var(--mono);
      font-size:9px;
      letter-spacing:1.2px;
      text-transform:uppercase;
      color:var(--dimmer);
    }
    .mobile-axis-row .line { flex:1; height:1px; background:var(--border); }
    .mobile-axis-row b { color:var(--green); font-weight:500; }
    .mobile-tech-grid {
      display:grid;
      grid-template-columns:repeat(4, 1fr);
      grid-template-rows:min-content 96px;
      gap:9px;
      align-items:end;
      width:100%;
      max-width:100%;
    }
    .mobile-cat-label {
      grid-column:span 4;
      font-family:var(--mono);
      font-size:8.5px;
      letter-spacing:1.3px;
      text-transform:uppercase;
      color:var(--dim);
      padding:3px 2px 0;
      line-height:1;
    }
    .mobile-cat-label.fe { color:var(--green); }
    .mobile-cat-label.api { color:var(--blue); }
    .mobile-cat-label.data { color:var(--amber); }
    .mobile-cat-label.infra,
    .mobile-cat-label.media { color:var(--text-sub); }
    .mobile-cat-label.first { grid-column:3 / -1; padding-left:0; }
    .mobile-cat-label.first .cat-stats { margin-left:5px; }
    .mobile-cat-label .cat-stats { color:inherit; font-weight:400; margin-left:7px; }
    .mobile-cat-label .cat-stats b { color:inherit; font-weight:600; }
    .mobile-cat-label .cat-stats .sep { color:inherit; opacity:.55; margin:0 5px; }
    .mobile-hero-text {
      grid-column:span 2;
      grid-row:1 / span 2;
      padding:0 4px 4px;
      display:flex;
      flex-direction:column;
      justify-content:flex-start;
      align-self:end;
      min-height:96px;
      min-width:0;
    }
    .mobile-hero-title {
      font-size:19px;
      font-weight:700;
      color:var(--text-bright);
      letter-spacing:-0.02em;
      line-height:1.1;
    }
    .mobile-hero-desc {
      font-family:var(--mono);
      font-size:10.5px;
      color:var(--text-sub);
      line-height:1.55;
      margin-top:6px;
      display:-webkit-box;
      -webkit-line-clamp:4;
      -webkit-box-orient:vertical;
      overflow:hidden;
    }
    .mobile-hero-link { color:var(--green); text-decoration:none; border-bottom:1px solid var(--green-border); }
    .mobile-tile {
      height:96px;
      background:var(--surface);
      border:1px solid var(--border-strong);
      border-radius:16px;
      box-shadow:var(--node-shadow);
      display:flex;
      flex-direction:column;
      padding:9px 10px 10px;
