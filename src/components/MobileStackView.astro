    }
    .mobile-panel-h-row { display:flex; align-items:center; gap:10px; min-width:0; }
    .mobile-panel-back {
      flex-shrink:0;
      background:transparent;
      border:none;
      color:var(--green);
      font-family:var(--mono);
      font-size:11px;
      padding:2px 4px 2px 0;
      cursor:pointer;
      display:flex;
      align-items:center;
      gap:4px;
    }
    .mobile-panel-name {
      flex:1;
      color:var(--text-bright);
      font-weight:600;
      font-size:15px;
      letter-spacing:-0.01em;
      min-width:0;
      line-height:1.2;
      overflow:hidden;
      text-overflow:ellipsis;
      white-space:nowrap;
    }
    .mobile-panel-tag {
      flex-shrink:0;
      font-size:10px;
      color:var(--green);
      border:1px solid var(--green-border);
      border-radius:3px;
      padding:1px 6px;
      font-family:var(--mono);
    }
    .mobile-panel-tag.api { color:var(--blue); border-color:var(--blue); }
    .mobile-panel-tag.data { color:var(--amber); border-color:var(--amber); }
    .mobile-panel-tag.infra,
    .mobile-panel-tag.media { color:var(--text-sub); border-color:var(--border-strong); }
    .mobile-panel-meta {
      font-family:var(--mono);
      font-size:10.5px;
      color:var(--text-sub);
      line-height:1.4;
    }
    .mobile-panel-meta b { color:var(--text-bright); font-weight:500; }
    .mobile-panel-meta .sep { color:var(--dimmer); margin:0 5px; }
    .mobile-panel-body {
      flex:1;
      overflow-y:auto;
      padding:12px 14px 32px;
      scrollbar-width:thin;
      -webkit-overflow-scrolling:touch;
    }
    .mobile-project-group { margin-bottom:11px; }
    .mobile-pcard,
    .mobile-dcard,
    .mobile-fcard,
    .mobile-ep-row {
