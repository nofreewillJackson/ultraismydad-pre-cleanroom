    .mobile-tile.empty { opacity:.5; box-shadow:none; }
    .mobile-ttop { display:flex; align-items:center; gap:6px; min-width:0; }
    .mobile-tdot { width:8px; height:8px; border-radius:2px; flex-shrink:0; background:var(--blue); }
