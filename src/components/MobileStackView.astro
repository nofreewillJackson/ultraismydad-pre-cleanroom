      margin-top:5px;
      background:var(--green);
    }
    .mobile-fcard.series .mobile-fcard-h .sdot { background:var(--amber); }
    .mobile-fcard-h .ntag { color:var(--dim); border:1px solid var(--border); margin-top:2px; }
    .mobile-fcard.series .mobile-fcard-h .ntag { color:var(--amber); border-color:var(--amber-border); }
    .mobile-fcard-link {
      display:block;
      color:inherit;
      text-decoration:none;
    }
    .mobile-fcard-link:hover .mobile-fcard { border-color:var(--border-hover); }
    .mobile-fcard-body { padding:9px 11px 11px; }
    .mobile-fcard-body .ndesc { font-size:11.5px; line-height:1.5; }
    .mobile-fcard-body .nmeta {
      margin-top:7px;
      font-family:var(--mono);
      font-size:10px;
      color:var(--dim);
      display:flex;
      flex-wrap:wrap;
      align-items:center;
      gap:4px 7px;
    }
    .mobile-status {
      padding:1px 6px;
      border-radius:3px;
      font-size:9.5px;
      background:var(--green-bg);
      color:var(--green);
      border:1px solid var(--green-border);
    }
    .mobile-ep-row {
      display:flex;
      align-items:center;
      gap:9px;
      padding:7px 11px 7px 8px;
      text-decoration:none;
      color:inherit;
      cursor:pointer;
      transition:border-color .12s;
    }
    .mobile-ep-thumb {
      width:44px;
      height:44px;
      flex-shrink:0;
      border-radius:5px;
      background:#000 center / cover;
      border:1px solid var(--border);
