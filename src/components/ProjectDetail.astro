---
import type { Project } from "../lib/data";
import { dayNum, fmtDateFull, isEmbeddable, renderMarkdownLite, toVideoEmbed } from "../lib/format";
import FileBrowser from "./FileBrowser.astro";

type Props = { project: Project };
const { project } = Astro.props;
const files = (project.files || []).filter((file) => file.visibility !== "private");
const tags = project.tags || [];
const shots = project.screenshots || [];
const embedUrl = isEmbeddable(project.link) ? project.link : "";
const hasDemo = Boolean(project.artifactHtml || embedUrl);
const hasRepo = Boolean(project.repo?.trim());
const defaultTab = hasDemo ? "demo" : "info";
const tabs = [
  { id: "info", label: "info" },
  ...(hasDemo ? [{ id: "demo", label: "live demo" }] : []),
  ...(hasRepo ? [{ id: "files", label: "files" }] : []),
];
const day = dayNum(project.date);
---
<a class="back" href="/list" data-back-to-last-index>← all projects</a>

<article data-tabs>
  <div class="meta">
    {day && <>day <b>{day}</b> · </>}{fmtDateFull(project.date)} · <span class:list={["status", project.status]}>{project.status}</span>
  </div>
  <h1 class="page-h1">{project.name}</h1>
  {project.desc && <p class="r-sub" style="white-space:normal;max-width:760px">{project.desc}</p>}
  {tags.length > 0 && <div class="pmod-meta">{tags.join(" · ")}</div>}

  <div class="pillrow">
    {project.link && <a class="pill" href={project.link} target="_blank" rel="noreferrer">site ↗</a>}
    {project.repo && <a class="pill" href={project.repo} target="_blank" rel="noreferrer">github ↗</a>}
    {project.media && project.media.includes("screen.studio")
      ? <a class="pill" href={project.media} target="_blank" rel="noreferrer">▶ demo</a>
      : project.media && <span class="pill static">▶ demo</span>}
  </div>

  <div class="tabbar">
    {tabs.map((tab) => (
      <button class:list={["tab", defaultTab === tab.id && "on"]} type="button" data-tab-target={tab.id}>
        <span class="tab-dot"></span>{tab.label}
      </button>
    ))}
  </div>

  <section class:list={["panel", defaultTab === "info" && "on"]} data-tab-panel="info">
    {project.longDesc && <div class="md" set:html={renderMarkdownLite(project.longDesc)}></div>}
    {(project.stack || []).length > 0 && (
      <div class="d-sec">
        <h4>stack</h4>
        <div class="d-chips">{project.stack?.map((item) => <span class="chip">{item}</span>)}</div>
      </div>
    )}
    {project.media && !project.media.includes("screen.studio") && (
      <div class="d-sec">
        <h4>media</h4>
        <div class="d-embed h">
          <iframe src={toVideoEmbed(project.media)} loading="lazy" title={`${project.name} media`} allowfullscreen></iframe>
        </div>
      </div>
    )}
    {shots.length > 0 && (
      <div class="d-sec">
        <h4>screenshots</h4>
        <div class="screenshot-grid">
          {shots.map((shot) => <a href={shot} target="_blank" rel="noreferrer"><img src={shot} alt="" loading="lazy" /></a>)}
        </div>
      </div>
    )}
    {files.length > 0 && (
      <div class="d-sec">
        <h4>files</h4>
        {files.map((file) => (
          <div class="file-row">
            <div class="file-head">
              <span>{file.name}</span>
              {file.visibility === "gated" && <span class="vis-locked">locked</span>}
            </div>
            {file.type === "link"
              ? <a class="ref" href={file.url} target="_blank" rel="noreferrer">{file.url} ↗</a>
              : file.visibility === "gated"
                ? <div class="file-locked">content locked — unlock to read</div>
                : <pre class="file-pre">{file.content}</pre>}
          </div>
        ))}
      </div>
    )}
  </section>

  {hasDemo && (
    <section class:list={["panel", defaultTab === "demo" && "on"]} data-tab-panel="demo">
      {project.artifactHtml
        ? <iframe class="demo-frame" srcdoc={project.artifactHtml} loading="lazy" title={`${project.name} live demo`}></iframe>
        : <iframe class="demo-frame" src={embedUrl} loading="lazy" title={`${project.name} live demo`}></iframe>}
    </section>
  )}

  {hasRepo && (
    <section class="panel" data-tab-panel="files">
      <FileBrowser repo={project.repo} />
    </section>
  )}
</article>
