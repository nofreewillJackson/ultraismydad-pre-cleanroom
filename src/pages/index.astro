---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import MobileStackView from "../components/MobileStackView.astro";
import {
  getMainProjects,
  getPublicProjects,
  getSeries,
  getSiteEntries,
  getStats,
  getTechnologies,
  resolveTechnologyIds,
  technologyCategoryPairs,
} from "../lib/data";
import { dateValue, fmtDate, isEmbeddable, slugify } from "../lib/format";

const [projects, entries] = await Promise.all([getPublicProjects(), getSiteEntries()]);
const stats = getStats(projects);
const mains = await getMainProjects(projects);
const seriesRecords = await getSeries(entries);
const technologies = await getTechnologies(entries);
const mainIds = new Set(mains.map((main) => main.id));
const seriesById = new Map(seriesRecords.map((series) => [series.id, series]));
const techById = new Map(technologies.map((tech) => [tech.id, tech]));
const techs = technologies.map((tech) => ({
  id: tech.id,
  name: tech.name,
  category: tech.category,
  count: tech.count,
}));
const techCategories = technologyCategoryPairs(technologies);

function canonicalTechIds(entry: any) {
  return resolveTechnologyIds({ stack: entry.stack || [], stackRefs: entry.stackRefs || [] }, technologies);
}

function labelSeries(value?: string) {
  if (!value) return "builds";
  return value
    .replace(/^series[-_]/, "")
    .replace(/[-_]+/g, " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());
}

function entryProjectId(entry: any) {
  return mainIds.has(entry.mainProjectId) ? entry.mainProjectId : "other";
}

function rowKind(key: string) {
  if (key === "builds") return "line";
  if (key.startsWith("entry-")) return "feature";
  return "series";
}

function rowInfo(entry: any) {
  const projectId = entryProjectId(entry);
  if (projectId === "other") {
    return { id: "builds", label: "other builds", kind: "line" };
  }
  if (entry.seriesId) {
    const series = seriesById.get(entry.seriesId);
    return {
      id: entry.seriesId,
      label: series?.name || labelSeries(entry.seriesId),
      kind: rowKind(entry.seriesId),
      desc: series?.desc || "",
      meta: series?.meta || "",
    };
  }
  return { id: `entry-${entry.id}`, label: entry.title, kind: entry.kind === "research" ? "research" : "feature" };
}

function cardPriority(entry: any) {
  if (entry.kind === "video") return 4;
  if (entry.kind === "research") return 3;
  if (entry.project?.artifactHtml || entry.project?.screenshots?.length) return 2;
  return 1;
}

function showcaseVisual(entry: any) {
  const hasArtifact = !!entry.project?.artifactHtml?.trim();
  const link = entry.project?.link || entry.embedUrl || "";
  const hasDemoUrl = !hasArtifact && isEmbeddable(link);
  if (entry.kind === "video" && entry.thumbnailUrl) return { isShowcase: true, previewKind: "video" };
  if (hasArtifact || hasDemoUrl) return { isShowcase: true, previewKind: "live demo" };
  return { isShowcase: false, previewKind: "" };
}

function dedupeCardKey(entry: any, key: string) {
  if (entry.seriesId && entry.date) return `${key}:${entry.date}`;
  return `${key}:${slugify(entry.title).slice(0, 52) || entry.id}`;
}

const rawRolodexes = mains.map((main) => {
  const rows = new Map<string, { id: string; label: string; kind: string; desc?: string; meta?: string; entryMap: Map<string, any>; latestDateValue: number }>();
  const owned = entries
    .filter((entry) => entryProjectId(entry) === main.id)
    .sort((a, b) => dateValue(b.date) - dateValue(a.date) || a.title.localeCompare(b.title));
  for (const entry of owned) {
    const info = rowInfo(entry);
    const key = info.id;
    const existing = rows.get(key);
    const row = existing || { id: info.id, label: info.label, kind: info.kind, desc: info.desc, meta: info.meta, entryMap: new Map(), latestDateValue: 0 };
    const visual = showcaseVisual(entry);
    const techIds = canonicalTechIds(entry);
    const stack = techIds.map((id) => techById.get(id)?.name).filter(Boolean);
    const artifactHtml = entry.project?.artifactHtml?.trim() || "";
    const thumbnailUrl = entry.thumbnailUrl || entry.project?.screenshots?.[0] || "";
    const card = {
      id: entry.id,
      kind: entry.kind,
      title: entry.title,
      desc: entry.desc || "",
      date: fmtDate(entry.date) || entry.date || "",
      rawDate: entry.date || "",
      dateValue: dateValue(entry.date),
      route: entry.route,
      status: entry.status || "launched",
      embedType: entry.embedType || (entry.kind === "video" ? "h" : "d"),
      thumbnailUrl,
      thumbnailMode: entry.thumbnailMode || (thumbnailUrl ? "static" : ""),
      artifactHtml,
      stack,
      techIds,
      previewKind: visual.previewKind,
      isShowcase: visual.isShowcase,
      priority: cardPriority(entry),
    };
    const cardKey = dedupeCardKey(entry, key);
    const prev = row.entryMap.get(cardKey);
    if (!prev || card.priority > prev.priority || (card.priority === prev.priority && card.dateValue >= prev.dateValue)) {
      row.entryMap.set(cardKey, card);
    }
    row.latestDateValue = Math.max(row.latestDateValue, card.dateValue);
    rows.set(key, row);
  }
  const normalizedRows = [...rows.values()]
    .map((row) => {
      const rowEntries = [...row.entryMap.values()].sort((a, b) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
      const stackCounts = new Map<string, number>();
      const techIdSet = new Set<string>();
      for (const item of rowEntries) {
        for (const name of item.stack || []) stackCounts.set(name, (stackCounts.get(name) || 0) + 1);
        for (const techId of item.techIds || []) techIdSet.add(techId);
      }
      const stack = [...stackCounts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0])).map(([name]) => name).slice(0, 6);
      const workId = `${main.id}-${slugify(row.id) || "line"}`;
      const entries = rowEntries.map(({ priority, ...item }) => item);
      const showcaseEntries = entries.filter((item) => item.isShowcase);
      return {
        id: row.id,
        label: row.label,
        kind: row.kind,
        desc: row.desc || "",
        meta: row.meta || "",
        workId,
        focusId: row.kind === "line" ? `pr_${main.id}` : `w_${workId}`,
        count: rowEntries.length,
        latestDateValue: row.latestDateValue,
        latestDate: rowEntries[0]?.rawDate || "",
        latestDateLabel: rowEntries[0]?.date || "",
        stack,
        techIds: [...techIdSet],
        entries,
        showcaseEntries,
      };
    })
    .filter((row) => row.entries.length)
    .sort((a, b) => b.latestDateValue - a.latestDateValue || a.label.localeCompare(b.label));
  const makeShowcaseRow = (row: any, entriesForRow: any[]) => {
    const showcaseEntries = entriesForRow.sort((a, b) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
    return {
      id: row.id,
      label: row.label,
      kind: row.kind,
      desc: row.desc || "Embeddable demos and videos from this project.",
      meta: row.meta || "showcase",
      workId: row.workId,
      focusId: row.focusId,
      count: showcaseEntries.length,
      latestDateValue: showcaseEntries[0]?.dateValue || 0,
      latestDate: showcaseEntries[0]?.rawDate || "",
      latestDateLabel: showcaseEntries[0]?.date || "",
      stack: [...new Set(showcaseEntries.flatMap((entry) => entry.stack || []))].slice(0, 6),
      techIds: [...new Set(showcaseEntries.flatMap((entry) => entry.techIds || []))],
      entries: showcaseEntries,
      showcaseEntries,
    };
  };
  const seriesShowcaseRows = normalizedRows.filter((row) => row.kind === "series" && row.showcaseEntries.length);
  const allShowcaseEntries = normalizedRows
    .flatMap((row) => row.showcaseEntries)
    .sort((a, b) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
  const showcaseRows = seriesShowcaseRows.length > 1
    ? seriesShowcaseRows.map((row) => makeShowcaseRow(row, row.showcaseEntries))
    : allShowcaseEntries.length
      ? [makeShowcaseRow({
          id: "showcase",
          label: "Embeds",
          kind: "line",
          desc: "Embeddable demos and videos from this project.",
          meta: "showcase",
          workId: `${main.id}-showcase`,
          focusId: `pr_${main.id}`,
        }, allShowcaseEntries)]
      : [];
  return {
    id: main.id,
    name: main.name,
    meta: main.meta,
    desc: main.desc,
    count: main.count,
    site: main.site,
    repo: main.repo,
    demo: main.demo,
    logoImg: main.logoImg,
    wordmark: main.wordmark,
    latestDateValue: normalizedRows.reduce((max, row) => Math.max(max, row.latestDateValue), 0),
    rows: normalizedRows,
    showcaseRows,
  };
}).filter((rolo) => rolo.rows.length);

const rolodexes = rawRolodexes.sort((a, b) => b.latestDateValue - a.latestDateValue || a.name.localeCompare(b.name));
const showcaseRolodexes = rawRolodexes
  .map((rolo) => ({
    ...rolo,
    rows: rolo.showcaseRows,
    count: rolo.showcaseRows.reduce((sum, row) => sum + row.entries.length, 0),
    latestDateValue: rolo.showcaseRows.reduce((max, row) => Math.max(max, row.latestDateValue), 0),
  }))
  .filter((rolo) => rolo.rows.length)
  .sort((a, b) => b.latestDateValue - a.latestDateValue || a.name.localeCompare(b.name));
const projectOrder = new Map(rolodexes.map((rolo, index) => [rolo.id, index]));
const orderedProjects = mains
  .filter((main) => projectOrder.has(main.id))
  .sort((a, b) => (projectOrder.get(a.id) ?? 99) - (projectOrder.get(b.id) ?? 99));

function entryWorkId(rolo: any, row: any, entry: any) {
  return `${rolo.id}-${slugify(row.id) || "line"}-${slugify(entry.id) || slugify(entry.title) || "entry"}`;
}

function stackEntryFromCard(rolo: any, row: any, entry: any) {
  return {
    id: entryWorkId(rolo, row, entry),
    kind: "feature",
    title: entry.title,
    desc: entry.desc || `${entry.title} under ${rolo.name}.`,
    date: entry.rawDate,
    dateLabel: entry.date,
    dateValue: entry.dateValue,
    status: entry.status || "launched",
    stack: entry.stack,
    techIds: entry.techIds || [],
    artifactHtml: entry.artifactHtml || "",
    route: entry.route,
    projectId: rolo.id,
    seriesId: "",
    children: [],
  };
}

function stackEntryFromRow(rolo: any, row: any) {
  const first = row.entries[0];
  const desc = row.kind === "feature"
    ? first?.desc || `${first?.title || row.label} under ${rolo.name}.`
    : row.desc || `${row.count} public entries in the ${row.label} line. Newest: ${first?.title || row.label}.`;
  return {
    id: row.workId,
    kind: row.kind,
    title: row.label,
    desc,
    date: row.latestDate,
    dateLabel: row.latestDateLabel,
    dateValue: row.latestDateValue,
    status: row.count === 1 ? (first?.status || "launched") : `${row.count} entries`,
    stack: row.stack,
    techIds: row.techIds || [],
    route: row.count === 1 ? first?.route : "",
    projectId: rolo.id,
    seriesId: row.kind === "series" ? row.id : "",
    children: row.entries.map((entry: any) => ({
      id: entry.id,
      kind: entry.kind,
      title: entry.title,
      route: entry.route,
      date: entry.date,
    })),
  };
}

const stackEntries = rolodexes.flatMap((rolo) => {
  const items = rolo.rows.flatMap((row) => (
    row.kind === "line"
      ? row.entries.map((entry) => stackEntryFromCard(rolo, row, entry))
      : [stackEntryFromRow(rolo, row)]
  )).sort((a, b) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
  return items.map((item, index) => ({ ...item, hiddenDefault: index >= 3 }));
});

const stackData = {
  categories: techCategories,
  techs,
  entries: stackEntries,
  projects: orderedProjects.map((main) => ({
    id: main.id,
    name: main.name,
    desc: main.desc,
    meta: `${main.meta} · ${main.count} entries`,
    count: main.count,
    site: main.site,
    repo: main.repo,
    demo: main.demo,
    logoImg: main.logoImg,
    wordmark: main.wordmark,
    markKey: main.markKey,
    markText: main.markText,
  })),
  rolodexes: showcaseRolodexes,
};

const mobileCategoryOrder = ["frontend", "api", "data", "infra", "media"];
function mobileCategory(category?: string) {
  if (category === "backend" || category === "agents") return "api";
  if (category === "other") return "infra";
  return category || "infra";
}

const mobileTechs = technologies
  .map((tech, index) => ({
    id: tech.id,
    name: tech.name,
    category: mobileCategory(tech.category),
    count: tech.count,
    sortOrder: index,
  }))
  .sort((a, b) => {
    const catA = mobileCategoryOrder.indexOf(a.category);
    const catB = mobileCategoryOrder.indexOf(b.category);
    return (catA === -1 ? 99 : catA) - (catB === -1 ? 99 : catB)
      || a.sortOrder - b.sortOrder
      || a.name.localeCompare(b.name);
  });

const mobileTechById = Object.fromEntries(mobileTechs.map((tech) => [tech.id, tech]));
const mobileBaseProjects = Object.fromEntries(mains.map((main) => [main.id, {
  id: main.id,
  name: main.name,
  desc: main.desc,
  meta: main.meta,
  mark: main.markText || "$_",
}]));

function mobileProjectId(entry: any) {
  const projectId = entryProjectId(entry);
  return projectId === "other" || projectId === "research" ? `entry:${entry.id}` : projectId;
}

function mobileCommon(entry: any) {
  return {
    id: entry.id,
    title: entry.title,
    desc: entry.desc || "",
    date: entry.date || "",
    dateLabel: fmtDate(entry.date) || entry.date || "",
    dateValue: dateValue(entry.date),
    status: entry.status || "launched",
    route: entry.route || "",
    projectId: mobileProjectId(entry),
    techIds: canonicalTechIds(entry).filter((id) => mobileTechById[id]),
  };
}

const mobileEntries = entries.map((entry) => {
  const common = mobileCommon(entry);
  const artifactHtml = entry.project?.artifactHtml?.trim() || "";
  const link = entry.project?.link || entry.embedUrl || "";
  const demoUrl = !artifactHtml && link && isEmbeddable(link) ? link : "";
  const isDemo = entry.kind !== "video" && Boolean(artifactHtml || demoUrl);
  const isEpisode = entry.kind === "video" || Boolean(entry.videoId);
  return {
    ...common,
    type: isDemo ? "demo" : isEpisode ? "episode" : "update",
    seriesId: entry.seriesId || "",
    meta: entry.kind === "video" ? "episode" : common.dateLabel,
    artifactHtml,
    demoUrl,
    thumbnailUrl: entry.thumbnailUrl || entry.project?.screenshots?.[0] || "",
    youtubeId: entry.youtubeId || entry.video?.youtubeId || "",
    orient: entry.embedType === "v" || entry.video?.format === "short" ? "v" : "h",
  };
}).filter((entry) => entry.techIds.length && (mainIds.has(entry.projectId) || entry.projectId.startsWith("entry:")));

const mobileProjects = { ...mobileBaseProjects };
for (const entry of mobileEntries) {
  if (!entry.projectId.startsWith("entry:")) continue;
  mobileProjects[entry.projectId] = {
    id: entry.projectId,
    name: entry.title,
    desc: entry.desc,
    meta: entry.dateLabel,
    mark: "•",
  };
}

const mobileChildrenByProject: Record<string, any> = {};
function mobileProjectBucket(projectId: string) {
  if (!mobileChildrenByProject[projectId]) mobileChildrenByProject[projectId] = { demos: [], updates: [], series: [] };
  return mobileChildrenByProject[projectId];
}

for (const entry of mobileEntries) {
  const bucket = mobileProjectBucket(entry.projectId);
  if (entry.type === "demo") {
    bucket.demos.push(entry);
  } else if (!entry.seriesId) {
    bucket.updates.push(entry);
  }
}

for (const series of seriesRecords) {
  const episodes = mobileEntries
    .filter((entry) => entry.type === "episode" && entry.seriesId === series.id)
    .sort((a, b) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
  if (!episodes.length) continue;
  const projectId = series.mainProjectId && mainIds.has(series.mainProjectId) ? series.mainProjectId : episodes[0].projectId;
  const techIds = [...new Set(episodes.flatMap((entry) => entry.techIds || []))];
  mobileProjectBucket(projectId).series.push({
    id: series.id,
    title: series.name,
    desc: series.desc,
    meta: series.meta || `${episodes.length} episodes`,
    dateLabel: episodes[0].dateLabel,
    dateValue: episodes[0].dateValue,
    projectId,
    techIds,
    episodes,
  });
}

Object.values(mobileChildrenByProject).forEach((bucket: any) => {
  bucket.demos.sort((a: any, b: any) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
  bucket.updates.sort((a: any, b: any) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
  bucket.series.sort((a: any, b: any) => b.dateValue - a.dateValue || a.title.localeCompare(b.title));
});

const mobilePanelItems = [
  ...mobileEntries,
  ...Object.values(mobileChildrenByProject).flatMap((bucket: any) => bucket.series.map((series: any) => ({
    id: `series-${series.id}`,
    title: series.title,
    dateValue: series.dateValue,
    dateLabel: series.dateLabel,
    projectId: series.projectId,
    techIds: series.techIds,
    type: "series",
  }))),
];

const mobileStackData = {
  techs: mobileTechs,
  techById: mobileTechById,
  projects: mobileProjects,
  items: mobilePanelItems,
  childrenByProject: mobileChildrenByProject,
};
---
<BaseLayout title="artlu.ai — stack spectrum" description="The artlu.ai stack view: a crawlable map of shipped projects, videos, and research across the 100 day build.">
  <Header active="stack" stats={stats} sticky="canvas" />
  <MobileStackView data={mobileStackData} />
  <div class="canvas-fallback page stack-mobile-fallback">
    <div class="col">
      <h2 class="sec-h">stack view</h2>
      <p class="muted">The stack canvas is desktop-first. Use the list view on smaller screens.</p>
      <a class="mobile-list-redirect" href="/list">open list view →</a>
    </div>
  </div>
  <div class="viewport stack-vp" id="viewport">
    <div class="world stack-world" id="world">
      <svg class="wires" id="wires"></svg>
      <div class="world-intro">
        <div class="wi-h">what is this?</div>
        <div class="wi-p">Everything shipped on artlu.ai, read across the stack: the tech each line uses, the shipped feature or series, the project it belongs to, and the latest demos or videos. Click any node to focus its lineage. Feeling overwhelmed? Check out <a class="wi-link" href="/list">List View</a>.</div>
      </div>
    </div>
  </div>
  <aside class="panel stack-panel" id="canvasPanel">
    <div class="p-top"><button class="p-x" type="button" id="panelClose">×</button></div>
    <div class="p-head">
      <div class="p-eyebrow"><span class="ed" id="panelDot"></span><span id="panelKind"></span></div>
      <div class="p-title" id="panelTitle"></div>
      <div class="p-sub" id="panelSub"></div>
    </div>
    <div class="p-body" id="panelBody"></div>
    <div class="p-foot">
      <a class="p-full" id="panelOpen" href="#">open page ↗</a>
      <a class="slug-page" id="panelSlug" href="#"></a>
    </div>
  </aside>
  <div class="hud">drag to pan · scroll to zoom · stack rail follows the visible features · click a node to focus</div>
  <div class="zoomctl">
    <button type="button" data-zoom="-">−</button>
    <button type="button" data-zoom="+">+</button>
    <button type="button" data-zoom="fit">fit</button>
  </div>
  <style is:global>
    body { overflow:hidden; }
    .topbar { position:relative; }
    .stack-vp {
      position:absolute;
      top:72px;
      left:0;
      right:0;
      bottom:0;
      overflow:clip;
      cursor:grab;
      background:
        linear-gradient(var(--grid-line) 1px, transparent 1px),
        linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
        radial-gradient(circle, var(--grid-dot, transparent) 1.5px, transparent 1.5px);
      background-size:160px 160px, 160px 160px, 32px 32px;
    }
    .stack-vp.grabbing { cursor:grabbing; }
    .stack-world {
      position:absolute;
      top:0;
      left:0;
      width:2100px;
      height:3200px;
      transform-origin:0 0;
    }
    .stack-world .wires {
      position:absolute;
      top:0;
      left:0;
      width:100%;
      height:100%;
      overflow:visible;
      pointer-events:none;
      z-index:1;
    }
    .stack-world .col-head {
      position:absolute;
      top:124px;
      display:flex;
      align-items:center;
      gap:10px;
      font-size:13px;
      color:var(--dim);
      letter-spacing:1.5px;
      text-transform:uppercase;
      z-index:2;
    }
    .stack-world .stack-toggle {
      border:0;
      background:transparent;
      color:var(--dim);
      font:inherit;
      letter-spacing:inherit;
      text-transform:inherit;
      padding:0;
      cursor:pointer;
      opacity:.72;
    }
    .stack-world .stack-toggle:hover { color:var(--text-sub); opacity:1; }
    .stack-world .axis-spine { position:absolute; width:1px; background:var(--border-strong); }
    .stack-world .axis-chip {
      position:absolute;
      transform:translate(-50%,-50%);
      white-space:nowrap;
      z-index:2;
      background:var(--bg);
      border:1px solid var(--border-strong);
      border-radius:5px;
      font-size:11px;
      font-weight:500;
      letter-spacing:1px;
      text-transform:uppercase;
      color:var(--dim);
      padding:5px 11px;
    }
    .stack-world .axis-cap {
      position:absolute;
      transform:translateX(-50%);
      white-space:nowrap;
      font-size:10px;
      letter-spacing:1px;
      text-transform:uppercase;
      color:var(--dimmer);
    }
    .stack-world .node {
      position:absolute;
      visibility:hidden;
      z-index:2;
      background:var(--surface);
      border:1px solid var(--border-strong);
      border-radius:8px;
      box-shadow:var(--node-shadow);
      cursor:pointer;
      overflow:hidden;
      transition:opacity .16s, border-color .14s, box-shadow .14s;
    }
    .stack-world.ready .node { visibility:visible; }
    .stack-world .node:hover { border-color:var(--border-hover); }
    .stack-world .node.sel { box-shadow:var(--node-shadow), 0 0 0 2px var(--border-hover); }
    .stack-world .node.dimmed { opacity:0.16; }
    .stack-world .node.stack-appear {
      --stack-opacity:1;
      animation:stack-stair-in .34s cubic-bezier(.2,.72,.18,1) both;
      animation-delay:var(--stack-delay, 0ms);
    }
    .stack-world .node.stack-appear.dimmed { --stack-opacity:.16; }
    @keyframes stack-stair-in {
      from { opacity:0; transform:translateY(-9px); filter:blur(2px); }
      to { opacity:var(--stack-opacity); transform:translateY(0); filter:blur(0); }
    }
    .stack-world .node.hidden-work,
    .stack-world .node.hidden-tech,
    .stack-world .node.hidden-project,
    .stack-world .node.hidden-rolodex { display:none; }
    .stack-world .node.focus-tech {
      z-index:8;
      border-color:var(--green-border);
      box-shadow:var(--node-shadow), 0 0 0 1px var(--green-border);
    }
    .stack-world .node.tech { width:206px; }
    .stack-world .node.work { width:272px; }
    .stack-world .node.work .nhead { align-items:flex-start; }
    .stack-world .node.work .nname {
      display:-webkit-box;
      -webkit-line-clamp:2;
