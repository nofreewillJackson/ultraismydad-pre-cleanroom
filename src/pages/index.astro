  </style>
  <script define:vars={{ stackData }}>
    const data = stackData;
    const TECH_X = 150;
    const WORK_X = 500;
    const PROJ_X = 880;
    const ROLO_X = 1260;
    const SPEC_X = 84;
    const DATE_X = 430;
    const nodes = {};
    const edges = [];
    const world = document.getElementById("world");
    const vp = document.getElementById("viewport");
    const topbar = document.getElementById("topbar");
    const svg = document.getElementById("wires");
    const panel = document.getElementById("canvasPanel");
    const panelDot = document.getElementById("panelDot");
    const panelKind = document.getElementById("panelKind");
    const panelTitle = document.getElementById("panelTitle");
    const panelSub = document.getElementById("panelSub");
    const panelBody = document.getElementById("panelBody");
    const panelOpen = document.getElementById("panelOpen");
    const panelSlug = document.getElementById("panelSlug");
    const techById = new Map(data.techs.map((tech) => [tech.id, tech]));
    const techCategoryRank = new Map(data.categories.map(([category], index) => [category, index]));
    const techGlobalRank = new Map(data.techs.map((tech, index) => [tech.id, index]));
    let active = null;
    let hover = null;
    let activeNodeId = null;
    let focusWorkId = null;
    let expanded = false;
    let showMoreBtn = null;
    let stackToggleBtn = null;
    let showAllTech = false;
    let selectionTechOrder = null;
    let viewportTechIds = new Set();
    let viewportTechOrder = [];
    let viewportStackTimer = null;
    let pan = { x: 24, y: 18 };
    let scale = 0.86;

    function esc(value) {
      return String(value || "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }
    function mk(id, cls, html, source) {
      const el = document.createElement("div");
      el.className = `node ${cls}`;
      el.dataset.id = id;
      el.innerHTML = html;
      world.appendChild(el);
      const node = { id, el, kind: cls.split(" ")[0], source: source || null, x: 0, y: 0, w: 0, h: 0, visible: true };
      nodes[id] = node;
      return node;
    }
    function previewSrcDoc(html) {
      const previewStyle = "<style data-artlu-preview>html,body{width:100%!important;height:100%!important;overflow:hidden!important;scrollbar-width:none!important;-ms-overflow-style:none!important;}body{position:relative!important;}*,*::before,*::after{scrollbar-width:none!important;-ms-overflow-style:none!important;}*::-webkit-scrollbar,html::-webkit-scrollbar,body::-webkit-scrollbar{display:none!important;width:0!important;height:0!important;}</style>";
      const value = String(html || "");
      if (/<\/head>/i.test(value)) return value.replace(/<\/head>/i, `${previewStyle}</head>`);
      return `${previewStyle}${value}`;
    }
    function card(entry) {
      const vertical = entry.embedType === "v";
      const thumb = entry.thumbnailUrl
        ? `<img src="${esc(entry.thumbnailUrl)}" alt="" loading="lazy">`
        : entry.artifactHtml
        ? `<iframe class="vframe" srcdoc="${esc(previewSrcDoc(entry.artifactHtml))}" loading="lazy" tabindex="-1" scrolling="no" sandbox="allow-scripts allow-same-origin allow-forms allow-popups"></iframe>`
        : entry.kind === "video" && entry.thumbnailUrl
        ? `<img src="${esc(entry.thumbnailUrl)}" alt="" loading="lazy"><div class="vplay">▶</div>`
        : entry.thumbnailUrl
          ? `<img src="${esc(entry.thumbnailUrl)}" alt="" loading="lazy">`
          : `<div class="vplaceholder">${esc(entry.previewKind || entry.kind || "project")}</div>`;
      if (!thumb) return "";
      return `<a class="vcard ${vertical ? "v" : "h"}" href="${esc(entry.route)}">
        <div class="vthumb">${thumb}</div>
        <div class="vmeta"><div class="vtitle">${esc(entry.title)}</div><div class="vdate">${esc(entry.date)}</div></div>
      </a>`;
    }
    function projectLinks(project, className = "nlink") {
      return [
        project.site ? `<a class="${className}" href="${esc(project.site)}" target="_blank" rel="noreferrer">site ↗</a>` : "",
        project.repo ? `<a class="${className}" href="${esc(project.repo)}" target="_blank" rel="noreferrer">github ↗</a>` : "",
        project.demo ? `<a class="${className}" href="${esc(project.demo)}" target="_blank" rel="noreferrer">demo ↗</a>` : "",
      ].filter(Boolean).join("");
    }
    function projectIcon(project) {
      if (project.logoImg) return `<img class="nlogo" src="${esc(project.logoImg)}" alt="" loading="lazy">`;
      if (project.markKey === "artlu") return `<span class="project-id mini" data-mark="artlu" aria-hidden="true"><span class="project-id-text">${esc(project.markText || "$_")}</span></span>`;
      if (project.markKey === "research") return '<span class="emoji-mini" aria-hidden="true">🧠</span>';
      if (project.markKey === "pipeline") return `<span class="project-id mini" data-mark="pipeline" aria-hidden="true"><span class="project-id-text">${esc(project.markText || "P")}</span></span>`;
      return "";
    }
    function projectNodeHTML(project) {
      const links = projectLinks(project);
      const icon = projectIcon(project);
      return `<div class="nhead" data-handle>${icon}<span class="nname">${esc(project.name)}</span><span class="ntag">project</span></div>
        <div class="nbody"><div class="ndesc">${esc(project.desc)}</div>${links ? `<div class="nlinks">${links}</div>` : ""}<div class="nmeta">${esc(project.meta)}</div></div>`;
    }
    function render() {
      data.techs.forEach((tech) => {
        const node = mk(`t_${tech.id}`, "tech hidden-tech", `<div class="tech-row"><span class="tdot"></span><span class="tname">${esc(tech.name)}</span><span class="tcat">${esc(tech.category)}</span></div>`, tech);
        node.visible = false;
      });
      data.entries.forEach((entry) => {
        const isSeries = entry.kind === "series";
        const glyph = isSeries ? '<span class="glyph series">◆</span>' : '<span class="sdot"></span>';
        const tag = isSeries ? "series" : entry.kind === "line" ? "line" : entry.kind;
        const node = mk(`w_${entry.id}`, `work${isSeries ? " series" : ""}`, `<div class="nhead" data-handle>${glyph}<span class="nname">${esc(entry.title)}</span><span class="ntag">${tag}</span></div>
          <div class="nbody"><div class="ndesc">${esc(entry.desc)}</div><div class="nmeta"><span class="status">${esc(entry.status)}</span>${esc(entry.dateLabel || entry.date)}</div></div>`, entry);
        node.el.classList.toggle("hidden-work", !!entry.hiddenDefault);
      });
      data.projects.forEach((project) => {
        mk(`pr_${project.id}`, "project", projectNodeHTML(project), project);
      });
      data.rolodexes.forEach((rolo) => {
        const singleRow = rolo.rows.length === 1;
        const rows = rolo.rows.map((row) => `<div class="rseries">
          ${singleRow ? "" : `<div class="rserlabel"><span class="glyph series">◆</span>${esc(row.label)}<span class="scount">· ${row.entries.length} entries</span></div>`}
          <div class="rrail" data-focus-id="${esc(row.focusId)}">
            <button class="rnav" type="button" data-row-scroll="-">&lt;</button>
            <div class="rstrip">${row.entries.map(card).join("")}</div>
            <button class="rnav" type="button" data-row-scroll="+">&gt;</button>
          </div>
        </div>`).join("");
        const countLabel = singleRow ? `${rolo.count} ${rolo.count === 1 ? "entry" : "entries"}` : rolo.count;
        mk(`ro_${rolo.id}`, "rolodex", `<div class="rhead" data-handle><span class="glyph series">▦</span><span class="nname">${esc(rolo.name)} showcase</span><span class="rcount">${esc(countLabel)}</span><button class="rall" type="button" data-open-project="${esc(rolo.id)}">all</button></div>
          <div class="rrows">${rows}</div>`, rolo);
      });
      [
        ["tech stack", TECH_X],
        ["updates", WORK_X],
        ["projects", PROJ_X],
        ["showcase", ROLO_X],
      ].forEach(([label, x]) => {
        const el = document.createElement("div");
