        }
      } else if (node.kind === "work") {
        const project = data.projects.find((item) => item.id === source.projectId);
        sub = `${source.kind} · latest ${source.dateLabel || source.date}`;
        sections = `<div class="p-sec"><h4>stack</h4>${(source.stack || []).map((name) => `<span class="tchip">${esc(name)}</span>`).join(" ")}</div>`;
        if (project) sections += `<div class="p-sec"><h4>rolls up to</h4>${lineRow(`pr_${project.id}`, project.name, "project", "var(--green)")}</div>`;
        if (source.children?.length) {
          sections += `<div class="p-sec"><h4>${source.children.length} entries in this line</h4>${source.children.slice(0, 12).map((entry) => `<a class="lrow" href="${esc(entry.route)}"><span class="ld" style="background:var(--amber)"></span><span class="lname">${esc(entry.title)}</span><span class="lkind">${esc(entry.kind)} · ${esc(entry.date)}</span><span class="arr">↗</span></a>`).join("")}</div>`;
        }
      } else if (node.kind === "project") {
        route = "#";
        const members = data.entries.filter((entry) => entry.projectId === source.id);
        const links = projectLinks(source, "p-link");
        kind = "project";
        sections = `${links ? `<div class="p-links">${links}</div>` : ""}
          <div class="p-sec"><h4>${members.length} lines in this project</h4>${members.slice(0, 12).map((entry) => lineRow(`w_${entry.id}`, entry.title, entry.kind, "var(--green)")).join("")}</div>`;
      } else if (node.kind === "rolodex") {
        route = "#";
        kind = "showcase";
        title = `${source.name} showcase`;
        sub = `${source.count} visual entries`;
        lead = "Latest embeddable demos and videos grouped into horizontally scrolling rows.";
        sections = source.rows.map((row) => `<div class="p-sec"><h4>${esc(row.label)}</h4>${row.entries.map((entry) => `<a class="lrow" href="${esc(entry.route)}"><span class="ld" style="background:var(--amber)"></span><span class="lname">${esc(entry.title)}</span><span class="lkind">${esc(entry.kind)}</span><span class="arr">↗</span></a>`).join("")}</div>`).join("");
      }
      panelDot.style.background = colors[node.kind] || "var(--green)";
      panelKind.textContent = kind;
      panelTitle.textContent = title;
      panelSub.textContent = sub;
      panelBody.innerHTML = `<div class="p-lead">${esc(lead)}</div>${sections}`;
      panelBody.scrollTop = 0;
      panelOpen.href = route;
      panelOpen.style.display = route === "#" ? "none" : "inline-flex";
      panelSlug.href = route;
      panelSlug.style.display = route === "#" ? "none" : "inline-block";
      panelSlug.textContent = route === "#" ? "" : route;
      panel.classList.toggle("no-route", route === "#");
      panel.classList.add("open");
      active = directLineageSet(id);
      Object.values(nodes).forEach((item) => item.el.classList.toggle("sel", item.id === id));
      applyFocus();
    }
    function closePanel() {
      panel.classList.remove("open");
      active = null;
      activeNodeId = null;
      focusWorkId = null;
      selectionTechOrder = null;
      Object.values(nodes).forEach((item) => item.el.classList.remove("sel"));
      refreshViewportStack(true);
    }
    function contentBounds() {
      const visible = Object.values(nodes).filter((node) => node.visible !== false);
      if (!visible.length) return { left: 0, top: 0, right: 1800, bottom: 1200 };
      return visible.reduce((box, node) => ({
        left: Math.min(box.left, node.x),
        top: Math.min(box.top, node.y),
        right: Math.max(box.right, node.x + node.w),
        bottom: Math.max(box.bottom, node.y + node.h),
      }), { left: SPEC_X - 42, top: 108, right: ROLO_X + 492, bottom: 900 });
    }
    function clampAxis(value, start, end, viewport, before = 42, after = 42) {
      const min = viewport - after - end * scale;
      const max = before - start * scale;
      if (min > max) return (viewport - (end - start) * scale) / 2 - start * scale;
      return Math.min(max, Math.max(min, value));
    }
    function clampPan() {
      if (!vp.clientWidth || !vp.clientHeight || !Object.keys(nodes).length) return;
      const bounds = contentBounds();
      pan.x = clampAxis(pan.x, bounds.left, bounds.right, vp.clientWidth, 42, 42);
      pan.y = clampAxis(pan.y, Math.min(0, bounds.top), bounds.bottom, vp.clientHeight, 18, 52);
    }
    function clearFocusState() {
      active = null;
      hover = null;
      activeNodeId = null;
      focusWorkId = null;
      selectionTechOrder = null;
      viewportTechIds = new Set();
      viewportTechOrder = [];
      window.clearTimeout(viewportStackTimer);
      panel.classList.remove("open");
      Object.values(nodes).forEach((item) => item.el.classList.remove("sel"));
    }
    function apply(options = {}) {
      clampPan();
      world.style.transform = `translate(${pan.x}px,${pan.y}px) scale(${scale})`;
      topbar.classList.toggle("stuck", pan.y < 12);
      if (options.refresh !== false && !selectionTechOrder && !showAllTech) scheduleViewportStack();
    }
    function zoomAt(mx, my, nextScale) {
      nextScale = Math.min(1.5, Math.max(0.4, nextScale));
      pan.x = mx - (mx - pan.x) * (nextScale / scale);
      pan.y = my - (my - pan.y) * (nextScale / scale);
      scale = nextScale;
      apply();
    }
    function resetView() {
      world.classList.remove("ready");
      clearFocusState();
      layout();
      buildAxes();
      const bounds = contentBounds();
      const contentWidth = Math.max(1, bounds.right - bounds.left);
      scale = Math.min(0.92, Math.max(0.42, (vp.clientWidth - 84) / (contentWidth + 84)));
      pan = { x: 42 - bounds.left * scale, y: 18 };
      apply({ refresh: false });
      refreshViewportStack(true);
      drawWires();
      world.classList.add("ready");
    }
    function resetToInitialView() {
      const run = () => resetView();
      window.requestAnimationFrame(run);
      window.setTimeout(run, 80);
      window.setTimeout(run, 240);
    }
    let panning = false;
    let panStart = null;
    let drag = null;
    let candidate = null;
    let moved = false;
    let down = { x: 0, y: 0 };
    vp.addEventListener("mousedown", (event) => {
      if (event.target.closest(".node")) return;
      panning = true;
      moved = false;
      down = { x: event.clientX, y: event.clientY };
      vp.classList.add("grabbing");
      panStart = { x: event.clientX - pan.x, y: event.clientY - pan.y };
    });
    world.addEventListener("mousedown", (event) => {
      if (event.target.closest("a")) return;
      const el = event.target.closest(".node");
      if (!el) return;
      if (event.target.closest(".rrows")) return;
      if (event.target.closest("[data-open-project]")) return;
      candidate = nodes[el.dataset.id];
      moved = false;
      down = { x: event.clientX, y: event.clientY };
      if (event.target.closest("[data-handle]")) drag = { node: candidate, x: candidate.x, y: candidate.y };
      event.stopPropagation();
    });
    window.addEventListener("mousemove", (event) => {
      if (Math.abs(event.clientX - down.x) + Math.abs(event.clientY - down.y) > 5) moved = true;
      if (panning) {
        pan = { x: event.clientX - panStart.x, y: event.clientY - panStart.y };
        apply();
      } else if (drag && moved) {
        drag.node.x = drag.x + (event.clientX - down.x) / scale;
        drag.node.y = drag.y + (event.clientY - down.y) / scale;
        drag.node.el.style.left = `${drag.node.x}px`;
        drag.node.el.style.top = `${drag.node.y}px`;
        drawWires();
      }
    });
    window.addEventListener("mouseup", (event) => {
      const wasPanning = panning;
      panning = false;
      vp.classList.remove("grabbing");
      if (candidate && !moved && !event.target.closest("a")) openPanel(candidate.id);
      else if (wasPanning && !moved && panel.classList.contains("open")) closePanel();
      drag = null;
      candidate = null;
    });
    vp.addEventListener("wheel", (event) => {
      event.preventDefault();
      const rect = vp.getBoundingClientRect();
      zoomAt(event.clientX - rect.left, event.clientY - rect.top, scale - event.deltaY * 0.0013);
    }, { passive:false });
    world.addEventListener("wheel", (event) => {
      const strip = event.target.closest(".rstrip");
      if (!strip || strip.scrollWidth <= strip.clientWidth + 2) return;
      event.preventDefault();
      event.stopPropagation();
      const dominantDelta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
      strip.scrollLeft += dominantDelta;
      updateRowNavs();
    }, { passive:false });
    world.addEventListener("mouseover", (event) => {
      if (activeNodeId) return;
      const row = event.target.closest("[data-focus-id]");
      const mod = event.target.closest(".node.rolodex");
      hover = row ? directLineageSet(row.dataset.focusId) : mod ? directLineageSet(mod.dataset.id) : null;
      applyFocus();
    });
    world.addEventListener("mouseleave", () => {
      hover = null;
      applyFocus();
    });
    world.addEventListener("click", (event) => {
      const scrollBtn = event.target.closest("[data-row-scroll]");
      if (scrollBtn) {
        event.preventDefault();
        const strip = scrollBtn.closest(".rrail")?.querySelector(".rstrip");
        if (strip) {
          const direction = scrollBtn.dataset.rowScroll === "+" ? 1 : -1;
          strip.scrollBy({ left: direction * Math.max(240, strip.clientWidth * 0.72), behavior: "smooth" });
          window.setTimeout(updateRowNavs, 220);
        }
        return;
      }
      const row = event.target.closest("[data-panel-id]");
      if (row) {
        event.preventDefault();
        openPanel(row.dataset.panelId);
      }
      const project = event.target.closest("[data-open-project]");
      if (project) {
        event.preventDefault();
        openPanel(`pr_${project.dataset.openProject}`);
      }
    });
    document.querySelectorAll("[data-zoom]").forEach((button) => {
      button.addEventListener("click", () => {
        const value = button.dataset.zoom;
      if (value === "fit") resetView();
      else {
        const rect = vp.getBoundingClientRect();
        zoomAt(rect.width / 2, rect.height / 2, scale + (value === "+" ? 0.14 : -0.14));
      }
      });
    });
    document.getElementById("panelClose").addEventListener("click", closePanel);
    panel.addEventListener("click", (event) => {
      const row = event.target.closest("[data-panel-id]");
      if (!row) return;
      event.preventDefault();
      openPanel(row.dataset.panelId);
    });
    world.addEventListener("scroll", (event) => {
      if (event.target.classList?.contains("rstrip")) updateRowNavs();
    }, true);
    render();
    if (stackToggleBtn) {
      stackToggleBtn.addEventListener("click", (event) => {
        event.preventDefault();
        event.stopPropagation();
        showAllTech = !showAllTech;
        refreshViewportStack(true);
      });
    }
    resetView();
    window.addEventListener("resize", () => {
      resetView();
    });
    window.addEventListener("load", resetToInitialView);
    window.addEventListener("pageshow", resetToInitialView);
  </script>
</BaseLayout>
