---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import VideoLong from "../../components/VideoLong.astro";
import VideoShort from "../../components/VideoShort.astro";
import { getPublicProjects, getStats, getVideoBundle, getVideoIndex } from "../../lib/data";

export async function getStaticPaths() {
  const videos = await getVideoIndex();
  return videos.map((video) => ({ params: { id: video.id } }));
}

const { id } = Astro.params;
const [bundle, projects] = await Promise.all([getVideoBundle(id), getPublicProjects()]);
const stats = getStats(projects);
const description = bundle.desc || bundle.coreMessage || bundle.title;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  name: bundle.title,
  description,
  uploadDate: bundle.shippedAt,
  duration: bundle.durationSec ? `PT${bundle.durationSec}S` : undefined,
  thumbnailUrl: bundle.video?.thumbnailUrl || bundle.thumbnailUrl,
  embedUrl: bundle.video?.youtubeId ? `https://www.youtube.com/embed/${bundle.video.youtubeId}` : undefined,
};
---
<BaseLayout title={`artlu.ai — ${bundle.title}`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
  <Header active="list" stats={stats} heatmapTooltip={bundle.format !== "short"} />
  <main class="page">
    {bundle.format === "short" ? <VideoShort bundle={bundle} /> : <VideoLong bundle={bundle} />}
  </main>
</BaseLayout>
