---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import { getPublicJournalEntries, getPublicProjects, getStats } from "../../lib/data";
import { fmtDateFull, renderMarkdownLite } from "../../lib/format";

export async function getStaticPaths() {
  const entries = await getPublicJournalEntries();
  return entries.map((entry, index) => ({
    params: { slug: entry.slug },
    props: { entry, prev: entries[index + 1] || null, next: entries[index - 1] || null },
  }));
}

const { entry, prev, next } = Astro.props;
const projects = await getPublicProjects();
const stats = getStats(projects);
---
<BaseLayout title={`artlu.ai — ${entry.title}`} description={entry.body?.slice(0, 155) || entry.title}>
  <Header active="log" stats={stats} />
  <main class="page">
    <article class="narrow">
      <a class="backlink" href="/log">← all log entries</a>
      <div class="e-meta"><span class="e-dot"></span>day {entry.day} · {fmtDateFull(entry.date)} · by {entry.author === "human" ? "the human" : "ai"}</div>
      <h1 class="page-h1">{entry.title}</h1>
      <div class="md" set:html={renderMarkdownLite(entry.body || "")}></div>
      <div class="e-foot">
        <div class="refs">
          {(entry.projectRefs || []).map((ref) => <a class="ref" href={`/project/${ref}`}>↗ {ref}</a>)}
          {(entry.tags || []).map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <nav class="entry-nav">
        {prev ? <a class="navcell prev" href={`/log/${prev.slug}`}><div class="navlabel">previous</div><div class="navtitle">{prev.title}</div></a> : <span></span>}
        {next ? <a class="navcell next" href={`/log/${next.slug}`}><div class="navlabel">next</div><div class="navtitle">{next.title}</div></a> : <span></span>}
      </nav>
    </article>
  </main>
</BaseLayout>
